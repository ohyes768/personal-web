# Gateway 环境变量配置示例
# 复制此文件为 .env 并修改相应配置

# 后端服务地址
# 在 Docker 网络中，使用服务名访问
DOUYIN_SERVICE_URL=http://douying-collect:8093
FINANCIAL_SERVICE_URL=http://financial-dashboard:8091
NEWS_SERVICE_URL=http://xwlb-analyze:8092

# Gateway 配置
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO

# 超时配置
REQUEST_TIMEOUT=300.0

# CORS 配置（根据实际域名修改）
CORS_ORIGINS=["http://localhost:3000","http://your-server-ip:3000"]
